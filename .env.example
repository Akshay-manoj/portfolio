# Contact form — Resend (https://resend.com)
# Create an API key in the Resend dashboard and paste it here.
RESEND_API_KEY=

# The address that receives contact-form submissions.
CONTACT_TO_EMAIL=you@example.com

# The "from" address. Until you verify your own domain in Resend,
# you can use the sandbox sender below.
CONTACT_FROM_EMAIL=Portfolio <onboarding@resend.dev>
